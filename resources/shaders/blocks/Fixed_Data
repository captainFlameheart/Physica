const float pi = 3.141592653589793;

const uint minus_1_uint = uint(-1);
const uint null_uint = minus_1_uint;
const uint decrement_uint = minus_1_uint;
const uint max_uint = 0xFFFFFFFF;

const uint uint_size_shift = 2u;
const uint uint_size = 1u << uint_size_shift;

const uint uint_bits_shift = 5u;
const uint uint_bits = 1u << uint_bits_shift;
const uint uint_bits_mask = uint_bits - 1u;

const uint uvec2_size_shift = 3u;
const uint uvec2_size = 1u << uvec2_size_shift;

const uint uvec4_size_shift = 4u;
const uint uvec4_size = 1u << uvec4_size_shift;

const uint float_size_shift = 2u;
const uint float_size = 1u << float_size_shift;

const uint vec2_size_shift = 3u;
const uint vec2_size = 1u << vec2_size_shift;

const uint vec4_size_shift = 4u;
const uint vec4_size = 1u << vec4_size_shift;

const uint alignment = 128u;	// Must be a power of two and at least 4!
const uint align_up_addition = alignment - 1u;
const uint align_up_mask = ~align_up_addition;
const uint common_base_alignment = alignment >> 4u;	// TODO: Rename to uvec4_base_alignment
const uint align_up_to_common_base_addition = common_base_alignment - 1u;
const uint align_up_to_common_base_mask = ~align_up_to_common_base_addition;

const uint point_mass_is_dead_shift = 0u;
const uint point_mass_is_dead_mask = 1u << point_mass_is_dead_shift;

const uint rigid_body_circle_contact_constraint_spawner_is_dead_shift = 0u;
const uint rigid_body_circle_contact_constraint_spawner_is_dead_mask = 1u << rigid_body_circle_contact_constraint_spawner_is_dead_shift;

const uint point_mass_distance_constraint_is_dead_shift = 0u;
const uint point_mass_distance_constraint_is_dead_mask = 1u << point_mass_distance_constraint_is_dead_shift;

const uint rigid_body_circle_contact_constraint_is_dead_shift = 0u;
const uint rigid_body_circle_contact_constraint_is_dead_mask = 1u << rigid_body_circle_contact_constraint_is_dead_shift;

const uint rigid_body_circle_contact_constraint_is_dying_shift = 1u;
const uint rigid_body_circle_contact_constraint_is_dying_mask = 1u << rigid_body_circle_contact_constraint_is_dying_shift;

const uint rigid_body_circle_contact_constraint_released_0_shift = 2u;
const uint rigid_body_circle_contact_constraint_released_0_mask = 1u << rigid_body_circle_contact_constraint_released_0_shift;

const uint rigid_body_circle_contact_constraint_released_1_shift = 2u;
const uint rigid_body_circle_contact_constraint_released_1_mask = 1u << rigid_body_circle_contact_constraint_released_1_shift;

const uint rigid_body_circle_contact_constraint_released_both_mask = rigid_body_circle_contact_constraint_released_0_mask | rigid_body_circle_contact_constraint_released_1_mask;

const uint dispatch_command_enabled_shift = 0u;
const uint dispatch_command_enabled_mask = 1u << dispatch_command_enabled_shift;

const uint draw_arrays_command_enabled_shift = 0u;
const uint draw_arrays_command_enabled_mask = 1u << draw_arrays_command_enabled_shift;

uint align_up(uint address)
{
	return (address + align_up_addition) & align_up_mask;
}

uint align_up_to_common_base(uint base)
{
	return (base + align_up_to_common_base_addition) & align_up_to_common_base_mask;
}

uint address_to_uvec4_index(uint address)
{
	return address >> uvec4_size_shift;
}

uint address_to_uvec2_index(uint address)
{
	return address >> uvec2_size_shift;
}

uint address_to_uint_index(uint address)
{
	return address >> uint_size_shift;
}

uint address_to_vec4_index(uint address)
{
	return address >> vec4_size_shift;
}

uint address_to_vec2_index(uint address)
{
	return address >> vec2_size_shift;
}

uint address_to_float_index(uint address)
{
	return address >> float_size_shift;
}


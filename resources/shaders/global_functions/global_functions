int compute_bounding_box_area_cost(in ivec4 bounding_box)
{
	return (bounding_box.z - bounding_box.x) * (bounding_box.w - bounding_box.y);
}

int compute_bounding_box_perimiter_cost(in ivec4 bounding_box)
{
	return (bounding_box.z - bounding_box.x) + (bounding_box.w - bounding_box.y);
}

int compute_bounding_box_cost(in ivec4 bounding_box)
{
	return compute_bounding_box_perimiter_cost(bounding_box);
}

uint compute_bounding_box_cost(in uvec4 bounding_box)
{
	return uint(compute_bounding_box_cost(ivec4(bounding_box)));
}

bool bounding_boxes_overlap(in ivec4 bounding_boxes[2u])
{
	return
	(
		all(lessThanEqual(bounding_boxes[0u].xy, bounding_boxes[1u].zw)) &&
		all(lessThanEqual(bounding_boxes[1u].xy, bounding_boxes[0u].zw))
	);
}

bool bounding_boxes_overlap(in ivec4 bounding_box_0, in ivec4 bounding_box_1)
{
	return
	(
		all(lessThanEqual(bounding_box_0.xy, bounding_box_1.zw)) &&
		all(lessThanEqual(bounding_box_1.xy, bounding_box_0.zw))
	);
}

bool bounding_boxes_are_separated(in ivec4 bounding_box_0, in ivec4 bounding_box_1)
{
	return
	(
		any(greaterThan(bounding_box_0.xy, bounding_box_1.zw)) ||
		any(greaterThan(bounding_box_1.xy, bounding_box_0.zw))
	);
}

bool bounding_boxes_are_separated(in uvec4 bounding_box_0, in uvec4 bounding_box_1)
{
	return bounding_boxes_are_separated(ivec4(bounding_box_0), ivec4(bounding_box_1));
}

uint round_up_to_power_of_two(uint x)
{
	if (x <= 1u)
	{
		return 1u;
	}

    uint most_significant_bit = uint(findMSB(x - 1u));
    return 1u << (most_significant_bit + 1u);
}

uint compute_mergeable_contact_detector_lookup_index(in uint index_0, in uint index_1, in uint lookup_table_capacity)
{
	uint min_index = min(index_0, index_1);
	uint max_index = max(index_0, index_1);

	uint hash = min_index * 0x9E3779B9u ^ max_index * 0x85EBCA6Bu;
	hash ^= hash >> 16;
	hash *= 0x7feb352du;
	hash ^= hash >> 15;
	hash *= 0x846ca68bu;
	hash ^= hash >> 16;

	return hash & (lookup_table_capacity - 1u);	// IMPORTANT: Assumes lookup_table_capacity is a power of two.
}


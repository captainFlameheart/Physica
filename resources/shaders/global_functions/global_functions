	void maybe_convert_to_bounding_box_contact_detector(in uint leaf_bounding_box_base_0, in uint leaf_bounding_box_base_1, in uint contact_detector_type, in uint index, in uvec2 indices)
	{
		uint bounding_box_index_0 = leaf_bounding_box_base_0 + indices.x;
		uint bounding_box_index_1 = leaf_bounding_box_base_1 + indices.y;

		uvec4 bounding_box_0 = uvec4_data.data[bounding_box_index_0];
		uvec4 bounding_box_1 = uvec4_data.data[bounding_box_index_1];

		if (bounding_boxes_are_separated(bounding_box_0, bounding_box_1))
		{
			uint bounding_box_contact_detector_index = spawn(bounding_box_contact_detector_type);
			uint bounding_box_contact_detector_capacity = fixed_data.capacities[bounding_box_contact_detector_type];
			if (bounding_box_contact_detector_index >= bounding_box_contact_detector_capacity)
			{
				undo_spawn(bounding_box_contact_detector_type);
				return;
			}

			uint inner_bounding_box_base = fixed_data.inner_bounding_box_base;
			uint bounding_box_contact_detector_indices_source_flags_base = fixed_data.bounding_box_contact_detector_indices_source_flags_base;

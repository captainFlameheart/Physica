					uvec4(null_uint, leaf_index, bounding_volume_hierarchy_root, inner_bounding_box_height);
				uvec2_data.data[inner_bounding_box_split_indices_base + inner_bounding_box_index] = uvec2(positive_null_uint);
				uvec4_data.data[bounding_box_contact_detector_indices_source_flags_base + inner_bounding_box_index] = uvec4(leaf_index, bounding_volume_hierarchy_root, null_uint, 0u);
				uvec4_data.data[inner_bounding_box_parent_children_height_base + leaf_index].x = inner_bounding_box_index;
				uvec4_data.data[inner_bounding_box_parent_children_height_base + bounding_volume_hierarchy_root].x = inner_bounding_box_index;
				uvec4 bounding_box = uvec4(0u);
				uvec4_data.data[inner_bounding_box_base + inner_bounding_box_index] = bounding_box;
				uint_data.data[inner_bounding_box_old_height_base + inner_bounding_box_index] = inner_bounding_box_height;

uint allocate_array(inout uint end_address, in uint capacity, in uint element_size, in uint element_size_shift)
{
	end_address = align_up(fixed_data.end_address);
	uint base = address_to_index(end_address, element_size_shift);
	end_address += capacity * element_size;
	return base;
}

uint allocate_uvec4_array(inout uint end_address, in uint capacity)
{
	return allocate_array(end_address, capacity, uvec4_size, uvec4_size_shift);
}

uint allocate_cleared_uvec4_array(in uint entity_type, uvec4 clear_value)
{
	uint capacity = fixed_data.capacities[entity_type];
	uint base = allocate_uvec4_array(fixed_data.end_address, capacity);
	for (uint i = 0; i < capacity; ++i)
	{
		uvec4_data.data[base + i] = clear_value;
	}
	return base;
}


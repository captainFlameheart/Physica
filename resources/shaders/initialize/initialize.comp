				bounding_volume_hierarchy_root = inner_bounding_box_index;

				++inner_bounding_box_index;

				uint_data.data[inner_bounding_box_height_delimiters_base + inner_bounding_box_height] = inner_bounding_box_index;
			}
		}
	}*/

	for (uint mergeable_bounding_box_contact_detector_lookup_head = 0u; mergeable_bounding_box_contact_detector_lookup_head < mergeable_bounding_box_contact_detector_lookup_table_capacity; ++mergeable_bounding_box_contact_detector_lookup_head)
	{
		uint_data.data[mergeable_bounding_box_contact_detector_lookup_table_base + mergeable_bounding_box_contact_detector_lookup_head] = null_uint;
	}

	//uint bounding_volume_hierarchy_height = inner_bounding_box_index - 1u;

	for (uint hover_highlighter_type = hover_highlighter_type_base; hover_highlighter_type < hover_highlighter_type_base + hover_highlighter_type_count; ++hover_highlighter_type)
	{
		fixed_data.read_counts[hover_highlighter_type] = 0u;
		fixed_data.write_counts[hover_highlighter_type] = 0u;
	}

	for (uint material_index = 0u; material_index < rigid_body_circle_material_count; ++material_index)
	{
		Rigid_Body_Circle_Material material = rigid_body_circle_materials[material_index];
		fixed_data.rigid_body_circle_material_albedos[material_index] = material.albedo;
		fixed_data.rigid_body_circle_material_emissions[material_index] = material.emission;
	}

	fixed_data.temp = null_uint;

	initialize_profiling_data();
}

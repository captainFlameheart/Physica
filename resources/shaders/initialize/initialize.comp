	}

	for (uint column = 0u; column < columns; ++column)
	{
		if (column != 0u && column != columns - 1u)
		{
			//continue;
		}
		float_data.data[point_mass_inverse_mass_base + column] = 0.0;
	}

	for (uint rigid_body_index = 0u; rigid_body_index < rigid_body_count; ++rigid_body_index)
	{
		vec2_data.data[rigid_body_inverse_mass_inertia_base + rigid_body_index] = vec2(0.5, 1.0);
		uint_data.data[rigid_body_constraint_start_base + rigid_body_index] = 0u;
		uint_data.data[rigid_body_constraint_end_base + rigid_body_index] = 0u;
		uvec4_data.data[rigid_body_read_position_flags_base + rigid_body_index] = uvec4(0u);
		uvec4_data.data[rigid_body_read_velocity_flags_base + rigid_body_index] = uvec4(0u);
		const uint rigid_body_columns = 300u;
		uvec4_data.data[rigid_body_write_position_flags_base + rigid_body_index] = uvec4
		(
			ivec4
			(
				4.0 * (-int(rigid_body_columns / 2u) + int(rigid_body_index % rigid_body_columns)) * meter_in_length_units,
				(2.0 + 2.0 * (-float(rigid_body_columns / 2u) + float(rigid_body_index / rigid_body_columns)) + 0.0 * float(rigid_body_index)) * meter_in_length_units,
				0.0 * float(rigid_body_index) * radian_in_angle_units,
				0
			)
		);
		uvec4_data.data[rigid_body_write_velocity_flags_base + rigid_body_index] = uvec4
		(
			ivec4
			(
				float(1 - 2 * int(rigid_body_index & 1)) * 1.0 * meters_per_second_in_length_units_per_time_unit, float(1 - 2 * int(rigid_body_index & 1)) * 0.3 * meters_per_second_in_length_units_per_time_unit,
				0.0 * radians_per_second_in_angle_units_per_time_unit, 0u
			)
		);
	}

	for (uint rigid_body_triangle_index = 0u; rigid_body_triangle_index < rigid_body_triangle_count; ++rigid_body_triangle_index)
	{
		uint_data.data[rigid_body_triangle_body_base + rigid_body_triangle_index] = rigid_body_triangle_index;
		uint vertex_index = rigid_body_triangle_vertex_base + rigid_body_triangle_index * 3u;
		const float radius = 0.5;
		vec2_data.data[vertex_index] = radius * vec2(0.0, 1.0);
		const float base_x_offset = 0.5 * sqrt(3.0);
		vec2_data.data[vertex_index + 1u] = radius * vec2(-base_x_offset, -0.5);
		vec2_data.data[vertex_index + 2u] = radius * vec2(base_x_offset, -0.5);
	}

	const uint unlit_count_factor = 5u;
	uint rigid_body_circle_material_indices[(rigid_body_circle_material_count / 2u) * (unlit_count_factor + 1u)];
	uint i = 0u;
	for (uint material_index = 0u; material_index < rigid_body_circle_material_count; material_index += 2u)
	{
		for (uint j = 0u; j < unlit_count_factor; ++j)
		{
			rigid_body_circle_material_indices[i++] = material_index;
		}

		rigid_body_circle_material_indices[i++] = material_index + 1u;
	}

	float radii[] =
	{
		0.5,
		0.5,
		0.4,
		0.6,
		0.7,
		0.3,
		0.2,
		1.0,
	};

	for (uint rigid_body_circle_index = 0u; rigid_body_circle_index < rigid_body_circle_count; ++rigid_body_circle_index)
	{
		uvec4_data.data[rigid_body_circle_body_position_radius_base + rigid_body_circle_index] = uvec4
		(
			rigid_body_circle_index,
			floatBitsToUint(vec3(0.0, 0.0, radii[rigid_body_circle_index % radii.length()]))
		);
		uint_data.data[rigid_body_circle_material_base + rigid_body_circle_index] = rigid_body_circle_material_indices[rigid_body_circle_index % rigid_body_circle_material_indices.length()];

		uvec4_data.data[leaf_bounding_box_parent_pad_pad_type_bases[rigid_body_circle_bounding_box_type] + rigid_body_circle_index] =
			uvec4(null_uint, 0u, 0u, rigid_body_circle_bounding_box_type);
		uvec4_data.data[leaf_bounding_box_bases[rigid_body_circle_bounding_box_type] + rigid_body_circle_index] = uvec4(0u);
	}

	/*uint rigid_body_circle_contact_constraint_spawner_index = 0u;
	for (uint rigid_body_circle_index_0 = 0u; rigid_body_circle_index_0 < rigid_body_circle_count - 1u; ++rigid_body_circle_index_0)
	{
		for (uint rigid_body_circle_index_1 = rigid_body_circle_index_0 + 1u; rigid_body_circle_index_1 < rigid_body_circle_count; ++rigid_body_circle_index_1)
		{
			uvec4_data.data[rigid_body_circle_contact_constraint_spawner_indices_flags_base + rigid_body_circle_contact_constraint_spawner_index] =
				uvec4(rigid_body_circle_index_0, rigid_body_circle_index_1, 0u, 0u);

			++rigid_body_circle_contact_constraint_spawner_index;
		}
	}*/

	for (uint default_skycircle_element_index = 0u; default_skycircle_element_index < default_skycircle_element_count; ++default_skycircle_element_index)
	{
		uvec4_data.data[default_skycircle_element_end_points_velocity_flags_base + default_skycircle_element_index] = uvec4
		(
			default_skycircle_element_end_points_velocity_flags[default_skycircle_element_index]
		);
		vec4_data.data[default_skycircle_element_radiance_base + default_skycircle_element_index] =
			default_skycircle_element_radiance[default_skycircle_element_index];
	}

	uint point_mass_distance_constraint_base_index = 0u;

	for (uint column = 0u; column < columns; ++column)
	{
		for (uint row = 0u; row < rows - 1u; ++row)
		{
			uint point_mass_distance_constraint_index = point_mass_distance_constraint_base_index + column * (rows - 1u) + row;

			uint index_0 = row * columns + column;
			uint index_1 = index_0 + columns;

			uvec2_data.data[point_mass_distance_constraint_flags_target_distance_base + point_mass_distance_constraint_index] = uvec2(0u, distance);

			// TODO: Atomic adds
			uint turn_0 = uint_data.data[point_mass_constraint_start_base + index_0];
			turn_0 += uint(-1);
			uint_data.data[point_mass_constraint_start_base + index_0] = turn_0;

			uint turn_1 = uint_data.data[point_mass_constraint_start_base + index_1];
			turn_1 += uint(-1);
			uint_data.data[point_mass_constraint_start_base + index_1] = turn_1;
			
			uvec4_data.data[point_mass_distance_constraint_indices_turns_base + point_mass_distance_constraint_index] = uvec4(index_0, index_1, turn_0, turn_1);
			uvec4_data.data[point_mass_distance_constraint_delta_position_velocity_base + point_mass_distance_constraint_index] = uvec4(0u);
		}
	}
	
	point_mass_distance_constraint_base_index += (columns - 1u) * (rows - 1u) + (rows - 2u) + 1u;

	for (uint row = 0u; row < rows; ++row)
	{
		for (uint column = 0u; column < columns - 1u; ++column)
		{
			uint point_mass_distance_constraint_index = point_mass_distance_constraint_base_index + row * (columns - 1u) + column;

			uint index_0 = row * columns + column;
			uint index_1 = index_0 + 1u;

			uvec2_data.data[point_mass_distance_constraint_flags_target_distance_base + point_mass_distance_constraint_index] = uvec2(0u, distance);

			// TODO: Atomic adds
			uint turn_0 = uint_data.data[point_mass_constraint_start_base + index_0];
			turn_0 += uint(-1);
			uint_data.data[point_mass_constraint_start_base + index_0] = turn_0;

			uint turn_1 = uint_data.data[point_mass_constraint_start_base + index_1];
			turn_1 += uint(-1);	
			uint_data.data[point_mass_constraint_start_base + index_1] = turn_1;
			
			uvec4_data.data[point_mass_distance_constraint_indices_turns_base + point_mass_distance_constraint_index] = uvec4(index_0, index_1, turn_0, turn_1);
			uvec4_data.data[point_mass_distance_constraint_delta_position_velocity_base + point_mass_distance_constraint_index] = uvec4(0u);
		}
	}

	uint last_point_mass_index = point_mass_count - 1u;
	uvec4_data.data[point_mass_write_position_velocity_base + last_point_mass_index].zw = uvec2(ivec2(
		1000.0 * meters_per_second_in_length_units_per_time_unit, 0.0 * meters_per_second_in_length_units_per_time_unit
	));
	float_data.data[point_mass_inverse_mass_base + last_point_mass_index] = 1.0;

	for (uint entity_type = 0u; entity_type < entity_type_count; ++entity_type)
	{
		if
		(
			entity_type != bounding_box_contact_detector_type &&
			entity_type != rigid_body_circle_contact_constraint_spawner_type_index &&
			entity_type != rigid_body_circle_contact_constraint_type_index
		)
		{
			continue;
		}

		uint old_death_index_base = old_death_index_bases[entity_type];
		uint death_index_base = death_index_bases[entity_type];
		for (uint index = 0u; index < capacities[entity_type]; ++index)
		{
			uint_data.data[old_death_index_base + index] = null_uint;
			uint_data.data[death_index_base + index] = null_uint;
		}
	}

	next_bounding_box_local_base = align_up_to_common_base(next_bounding_box_local_base);

	create_balanced_bounding_volume_hierarchy
	(
		end_base_address,
		rigid_body_circle_count,
		leaf_bounding_box_local_bases,
		next_bounding_box_local_base,
		inner_bounding_box_parent_children_height_base,
		inner_bounding_box_split_indices_base,
		inner_bounding_box_migration_entry_base,
		inner_bounding_box_old_height_base,
		bounding_box_contact_detector_indices_source_flags_base,
		inner_bounding_box_height_delimiters_base,
		inner_bounding_box_height_delimiters_capacity
	);

	/*uint bounding_volume_hierarchy_root = max_uint;
	uint inner_bounding_box_index = 0u;
	for (uint leaf_bounding_box_type = 0u; leaf_bounding_box_type < leaf_bounding_box_type_count; ++leaf_bounding_box_type)
	{
		// TODO: Generalize
		if (leaf_bounding_box_type != rigid_body_circle_bounding_box_type)
		{
			continue;
		}
		uint leaf_count = rigid_body_circle_count;
		// TODO: Store base in fixed_data.
		uint base = leaf_bounding_box_local_bases[leaf_bounding_box_type] - next_bounding_box_local_base;
		fixed_data.temp = base;	// TODO: Remove
		for (uint leaf = 0u; leaf < leaf_count; ++leaf)
		{
			uint leaf_index = base + leaf;
			if (bounding_volume_hierarchy_root == max_uint)
			{
				bounding_volume_hierarchy_root = leaf_index;
			}
			else
			{
				uint inner_bounding_box_height = inner_bounding_box_index;

void OLD_split_recursively
(
	in uint indices_source_flags_base,
	in uint bounding_box_parent_children_height_base,
	in uint bounding_box_base,
	in uint capacity,
	in uint index,
	in uvec4 indices_source_flags,
	in ivec4 bounding_boxes[2u]
)
{
	bvec2 is_inner = bvec2
	(
		int(indices_source_flags.x) >= 0,
		int(indices_source_flags.y) >= 0
	);
	if (any(is_inner))
	{
		uint detector_index = index;

		while (true)
		{	// Split logic.

			// Determine which box to split.
			uint cost_0 = compute_bounding_box_cost(bounding_boxes[0u]);
			uint cost_1 = compute_bounding_box_cost(bounding_boxes[1u]);
		
			uint split_side = uint((cost_1 > cost_0 || (cost_0 == cost_1 && indices_source_flags.y > indices_source_flags.x)) && is_inner.y);
			uint unsplit_side = split_side ^ 1u;
			
			uint split_index = indices_source_flags[split_side];
			uint unsplit_index = indices_source_flags[unsplit_side];
			
			uvec4 split_parent_children_height = uvec4_data.data[bounding_box_parent_children_height_base + split_index];
		
			// Update current detector -> one child.
			indices_source_flags[split_side] = split_parent_children_height.y;
			uvec4_data.data[indices_source_flags_base + detector_index] = indices_source_flags;	// TODO: Use index variable as detector_index.

			// Create new detector -> other child.
			uint new_detector_index = atomicAdd(fixed_data.write_counts[bounding_box_contact_detector_type], 1u);
			if (new_detector_index >= capacity)	// MUST TODO: Retry shader logic.
			{
				atomicAdd(fixed_data.write_counts[bounding_box_contact_detector_type], minus_1_uint);
				return;
			}

			indices_source_flags = uvec4(split_parent_children_height.z, unsplit_index, detector_index, 0u);
			uvec4_data.data[indices_source_flags_base + new_detector_index] = indices_source_flags;

			// IMPORTANT TODO: One of these fetches is redundant.
			bounding_boxes[0u] = ivec4(uvec4_data.data[bounding_box_base + indices_source_flags.x]);
			bounding_boxes[1u] = ivec4(uvec4_data.data[bounding_box_base + indices_source_flags.y]);

			is_inner[0u] = (int(indices_source_flags.x) >= 0);
			is_inner[1u] = (int(indices_source_flags.y) >= 0);

			detector_index = new_detector_index;

			if (bounding_boxes_overlap(bounding_boxes))
			{
				if (any(is_inner))
				{
					continue;	// Split the new detector as well.
				}
				else
				{
					convert_to_specific_detector(bounding_box_parent_children_height_base, bounding_box_base, detector_index, indices_source_flags);
				}
			}
			
			// IMPORTANT TODO: Avoid the need for backtracking by using next pointers instead of source pointers (ask ChatGPT).
			while (true)
			{	// Backtrack.
				uvec4_data.data[indices_source_flags_base + detector_index].z = null_uint;
				detector_index = indices_source_flags.z;	// Follow source pointer.
				
				indices_source_flags = uvec4_data.data[indices_source_flags_base + detector_index];

				bounding_boxes[0u] = ivec4(uvec4_data.data[bounding_box_base + indices_source_flags.x]);
				bounding_boxes[1u] = ivec4(uvec4_data.data[bounding_box_base + indices_source_flags.y]);
				
				is_inner[0u] = (int(indices_source_flags.x) >= 0);
				is_inner[1u] = (int(indices_source_flags.y) >= 0);

				if (bounding_boxes_overlap(bounding_boxes))
				{
					if (any(is_inner))
					{
						break;	// Resume splitting from this detector.
					}
					else
					{
						convert_to_specific_detector(bounding_box_parent_children_height_base, bounding_box_base, detector_index, indices_source_flags);
					}
				}
				if (detector_index == index)
				{
					return;
				}
			}
		}
	}
	else
	{
		convert_to_specific_detector(bounding_box_parent_children_height_base, bounding_box_base, index, indices_source_flags);	//  IMPORTANT TODO: Splitting logic.
	}
}


#define PRE_TICK_ENTITIES_PERFORM_COMPACTION_DETERMINE_FLOW(entity_type, killed_ring_base, source_kill_items_ring_base, killed, source)\
{\
	uint kill_item = gl_GlobalInvocationID.x;\
	uint kill_base = fixed_data.old_kill_bases[entity_type];\
	uint kill_end = fixed_data.old_kill_ends[entity_type];\
	uint kill_item_ring_index = kill_base + kill_item;\
	if (kill_item_ring_index >= kill_end)\
	{\
		return;\
	}\
	uint capacity = fixed_data.capacities[entity_type];\
	kill_item_ring_index -= uint(kill_item_ring_index >= capacity) * capacity;\
	\
	uint write_count = fixed_data.old_write_counts[entity_type];\
	\
	uint source_kill_items_ring_base = fixed_data.source_kill_items_ring_base;\
	\
	source = kill_item;\
	\
	uint default_source_kill_items_index = source_kill_items_ring_base + kill_item_ring_index;\
	uint source_kill_item = uint_data.data[default_source_kill_items_index];\
	\
	while (source_kill_item != null_uint)\
	{\
		source = source_kill_item;\
		\
		uint source_ring_index = kill_base + source;\
		source_ring_index -= uint(source_ring_index >= capacity) * capacity;\
		source_kill_item = uint_data.data[source_kill_items_ring_base + source_ring_index];\
	}\
	\
	source = write_count - 1u - source;\
	\
	uint_data.data[default_source_kill_items_index] = null_uint;\
	\
	uint killed_ring_base = fixed_data.killed_ring_base;\
	uint killed_index = killed_ring_base + kill_item_ring_index;\
	killed = uint_data.data[killed_index];\
}

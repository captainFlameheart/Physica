#define PRE_TICK_ENTITIES_PERFORM_COMPACTION_DETERMINE_FLOW(entity_type, killed, source)\
{\
	uint kill_item = gl_GlobalInvocationID.x;\
	uint kill_count = fixed_data.old_kill_counts[entity_type];\
	if (kill_item >= kill_count)\
	{\
		return;\
	}\
	\
	uint write_count = fixed_data.old_write_counts[entity_type];\
	\
	uint death_index_base = fixed_data.old_death_index_bases[entity_type];\
	uint killed_base = fixed_data.old_killed_bases[entity_type];\
	\
	killed = uint_data.data[killed_base + kill_item];\
	\
	uint death_index = kill_item;\
	do\
	{\
		source = write_count - 1u - death_index;\
		if (source <= killed)\
		{\
			return;\
		}\
		death_index = uint_data.data[death_index_base + source];\
	} while (death_index != null_uint);\
}
#define PRE_TICK_ENTITIES_COMMIT_COUNTS(entity_type_base, entity_subtype_count, clear_deaths_program_base, perform_compaction_program_base, tick_entities_program_base, local_sizes_flags)\
{\
	uint index = gl_GlobalInvocationID.x;\
	if (index >= entity_subtype_count)\
	{\
		return;\
	}\
	\
	uint entity_type = entity_type_base + index;\
	uint clear_deaths_program_index = clear_deaths_program_base + index;\
	uint perform_compaction_program_index = perform_compaction_program_base + index;\
	uint tick_entities_program_index = tick_entities_program_base + index;\
	uvec4 local_sizes_flags = local_sizes_flags[index];\
	\
	uint capacity = fixed_data.capacities[entity_type];\
	\
	uint read_count = fixed_data.read_counts[entity_type];\
	uint write_count = fixed_data.write_counts[entity_type];\
	uint kill_count = fixed_data.kill_counts[entity_type];\
	\
	uint old_kill_count = fixed_data.old_kill_counts[entity_type];\
	fixed_data.old_old_kill_counts[entity_type] = old_kill_count;\
	\
	fixed_data.old_write_counts[entity_type] = write_count;\
	fixed_data.old_kill_counts[entity_type] = kill_count;\
	\
	read_count = write_count - kill_count;\
	write_count = read_count;\
	\
	fixed_data.read_counts[entity_type] = read_count;\
	fixed_data.write_counts[entity_type] = write_count;\
	fixed_data.kill_counts[entity_type] = 0u;\
	\
	uint previous_old_death_index_base = fixed_data.old_death_index_bases[entity_type];\
	fixed_data.old_death_index_bases[entity_type] = fixed_data.death_index_bases[entity_type];\
	fixed_data.death_index_bases[entity_type] = previous_old_death_index_base;\
	\
	uint previous_old_killed_base = fixed_data.old_killed_bases[entity_type];\
	fixed_data.old_killed_bases[entity_type] = fixed_data.killed_bases[entity_type];\
	fixed_data.killed_bases[entity_type] = previous_old_killed_base;\
	\
	commands.dispatch_commands[clear_deaths_program_index].work_group_count_x =\
		(old_kill_count + local_sizes_flags.x - 1u) / local_sizes_flags.x;\
	commands.dispatch_commands[perform_compaction_program_index].work_group_count_x =\
		(kill_count + local_sizes_flags.y - 1u) / local_sizes_flags.y;\
	commands.dispatch_commands[tick_entities_program_index].work_group_count_x =\
		(read_count + local_sizes_flags.z - 1u) / local_sizes_flags.z;\
}
layout(local_size_x = 1u) in;
void main()
{
	float cursor_scale = fixed_data.cursor_scale;
	uint cursor_icon_index = fixed_data.cursor_icon_index;
	vec4 cursor_icon_offset_scale = fixed_data.cursor_icon_offset_scales[cursor_icon_index];
	cursor_scale = lerp(cursor_scale, cursor_icon_offset_scale.z, 0.00001, delta_time);
	fixed_data.cursor_scale = cursor_scale;
}
